# ────────────────────────────────────────────────────────────────────
# Cisco/Neeve NTP+DNS bench-test rig — per-device configuration
# ────────────────────────────────────────────────────────────────────
#
# Copy this file to `.env` and fill in the values for the device you
# are testing. The rig is generic: 1–2 DNS IPs and 1 NTP target
# (FQDN or IP literal) is all it needs.
#
# Defaults below match the first device under test — override per device.
#
# Syntax notes (this file is sourced as bash AND parsed by docker compose):
# - One `KEY=value` per line; no spaces around `=`.
# - Quote any value that contains spaces or shell-special chars (e.g. NIC names).
# - Comments start with `#` and run to end of line.
# - Lines starting with `#` and blank lines are ignored by both parsers.

# ── DNS ─────────────────────────────────────────────────────────────

# Primary DNS IP the device under test points at (REQUIRED).
# Our DNS server will bind to this IP and answer all queries.
DNS_PRIMARY_IP=10.0.0.53

# Secondary DNS IP, if the device has one configured (OPTIONAL).
# Leave blank or comment out to disable the secondary listener.
DNS_SECONDARY_IP=10.0.0.54

# ── NTP ─────────────────────────────────────────────────────────────

# What the device tries to reach for NTP.
# Either a FQDN (e.g., `ntp2.wbg.org`) or an IP literal (e.g., `10.0.0.123`).
# - FQDN: our DNS short-circuits this name to NTP_BIND_IP.
# - IP:   our NTP server binds directly at this IP; no DNS interception
#         for NTP needed (DNS still serves any other queries the node makes).
NTP_TARGET=ntp2.wbg.org

# IP that our chrony container binds on.
# - If NTP_TARGET is a FQDN: this is the IP the DNS server hands out.
# - If NTP_TARGET is an IP:  set NTP_BIND_IP equal to NTP_TARGET.
NTP_BIND_IP=10.0.0.123

# ── Host (Windows) ─────────────────────────────────────────────────

# The cabled Windows NIC name (used by setup-host-nic.ps1 to add IP aliases).
# Find yours with: Get-NetAdapter | Format-Table Name, InterfaceDescription, Status
# Quote the value if it contains spaces (NIC names commonly do, e.g., "Ethernet 4").
HOST_NIC_NAME="Ethernet 4"

# Subnet the device under test lives on (CIDR), used for chrony's allow rule.
# Must include both the device's IP and the bound DNS/NTP IPs.
NODE_SUBNET=10.0.0.0/24
