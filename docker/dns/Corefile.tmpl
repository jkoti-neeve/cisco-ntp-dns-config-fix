# CoreDNS configuration — generated from .env by scripts/render-config.sh.
#
# Behaviour:
# - Bind on the DNS IP(s) the device under test points at (1 or 2).
# - Log every query to stdout (capture-then-respond).
# - Answer from the seed.hosts file when a record matches; otherwise NXDOMAIN
#   (we are isolated — there is no upstream resolver to forward to).
. {
    bind ${DNS_BIND_LINE}
    log
    errors
    hosts /etc/coredns/zones/seed.hosts {
        # No fallthrough: unmatched names get NXDOMAIN (logged above).
    }
}
